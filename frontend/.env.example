# Copy to .env.local and set values from Cognito + CloudFormation output RestApiUrl.

VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_USER_POOL_CLIENT_ID=
# REST API (v1): base URL must include stage path, e.g. https://xxxx.execute-api.us-east-1.amazonaws.com/Prod — no trailing slash
VITE_API_URL=

# Optional: Cognito Hosted UI domain (e.g. your-prefix.auth.us-east-1.amazoncognito.com). When set, Amplify uses redirectSignIn/redirectSignOut from window.location.origin. Also add the same URLs to the app client Callback URLs / Sign-out URLs in Cognito.
# VITE_COGNITO_HOSTED_UI_DOMAIN=
